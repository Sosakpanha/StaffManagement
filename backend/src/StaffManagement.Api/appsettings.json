{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "AllowedHosts": "*",
  "Staff": {
    "Retention": {
      "Enabled": true,
      "RetentionDays": 90,
      "IntervalHours": 24
    }
  }
}
