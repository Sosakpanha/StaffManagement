# Copy this file to `.env` and adjust values as needed.
# The .env file is gitignored.

# ----- SQL Server (used by docker-compose) -----
# Must satisfy SQL Server's password policy: 8+ chars, upper/lower/digit/symbol.
MSSQL_SA_PASSWORD=ChangeMe_DevPassword123!

# ----- API configuration (used when running the API locally) -----
# .NET reads `__` as the section separator: `Jwt__SigningKey` => `Jwt:SigningKey`.

# Connection string the API uses to reach the SQL Server container.
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=StaffManagement;User Id=sa;Password=ChangeMe_DevPassword123!;TrustServerCertificate=True;Encrypt=False

# JWT signing key — must be at least 32 ASCII characters for HS256.
Jwt__SigningKey=devkey-replace-me-with-a-real-32-plus-character-secret
Jwt__Issuer=StaffManagement.Api
Jwt__Audience=StaffManagement.Frontend
Jwt__ExpiresMinutes=60

# ----- Frontend (Vite) -----
VITE_API_BASE_URL=http://localhost:5000
