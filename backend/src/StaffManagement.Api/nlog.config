<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      autoReload="true">

  <targets>
    <target xsi:type="ColoredConsole"
            name="console"
            layout="${time}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message} ${exception:format=tostring}" />

    <target xsi:type="File"
            name="file"
            fileName="logs/${shortdate}.log"
            layout="${longdate}|${level:uppercase=true:padding=-5}|${logger}|${message} ${exception:format=tostring}"
            archiveAboveSize="10485760"
            maxArchiveFiles="10" />
  </targets>

  <rules>
    <!-- Let the framework's HttpLogging middleware through; it's the one
         framework logger we explicitly opted into via AddHttpLogging. -->
    <logger name="Microsoft.AspNetCore.HttpLogging.*" minlevel="Info" writeTo="console,file" final="true" />

    <!-- Suppress everything else from Microsoft.* and System.Net.Http.* at Info. -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <logger name="*" minlevel="Info" writeTo="console,file" />
  </rules>
</nlog>
